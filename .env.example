PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wolf_staff_hub
SESSION_SECRET=replace-with-a-long-random-secret
USE_MOCK_DATA=true
CURRENT_RMS_SUBDOMAIN=
CURRENT_RMS_API_KEY=
CURRENT_RMS_WEBHOOK_SECRET=
ALLOWED_ORIGINS=http://localhost:3000
CACHE_SECONDS=55
MAX_OPPORTUNITIES=45
INCLUDE_CUSTOMER_NAME=true
ENABLE_DIAGNOSTICS=false
